@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ex: <https://example.org/people/> .

ex:PersonShape a sh:NodeShape ;
  sh:targetClass foaf:Person ;
  sh:property [
    sh:path foaf:name ;
    sh:minCount 1
  ] ;
  sh:property [
    sh:path foaf:mbox ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI
  ] .
